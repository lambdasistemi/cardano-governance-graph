  gb:from n:constitution ; gb:to n:guardrails-script ; gb:predicate gbedge:codified%20in ;
  rdfs:label "codified in" ; gb:description """The Constitution's enforceable rules — particularly Appendix I's parameter ranges and treasury limits — are codified in the on-chain Guardrails Script. The Constitution provides the authoritative rules; the script automates enforcement of the programmatically expressible subset.""" ;
  gb:edgeIndex 41 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-new-constitution cardano:affects n:constitution .
n:action-new-constitution gbedge:modifies n:constitution .
e:42 a gb:EdgeAssertion ;
  gb:from n:action-new-constitution ; gb:to n:constitution ; gb:predicate gbedge:modifies ;
  rdfs:label "modifies" ; gb:description """The only mechanism for amending the Cardano Constitution. The action includes an anchor to the new text. Requires DRep 75% and CC 2/3 majority. The current Constitution was ratified at the Buenos Aires Constitutional Convention in December 2024.""" ;
  gb:edgeIndex 42 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

