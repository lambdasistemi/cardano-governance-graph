  rdfs:label "can change" ; gb:description """Economic group includes txFeePerByte, txFeeFixed, stakeAddressDeposit, stakePoolDeposit, monetaryExpansion, treasuryCut, minPoolCost, utxoCostPerByte, executionUnitPrices, and minFeeRefScriptCostPerByte. Changes require CC 2/3 and DRep 67%.""" ;
  gb:edgeIndex 32 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

