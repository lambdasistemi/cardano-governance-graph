  rdfs:label "can update" ; gb:description """Can optionally include a new Guardrails Script hash. This is the only mechanism for updating the enforcement script, ensuring it stays synchronized with constitutional amendments.""" ;
  gb:edgeIndex 43 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-no-confidence cardano:putsIntoNoConfidenceState n:cc .
