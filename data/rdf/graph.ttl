  gb:from n:guardrails-script ; gb:to n:param-exceptions ; gb:predicate gbedge:enforces ;
  rdfs:label "enforces" ; gb:description """The Guardrails Script implements the per-parameter threshold exceptions on-chain. When a Protocol Parameter Change governance action is submitted, the script checks not just the permitted value ranges but also whether the correct voting bodies and thresholds apply for each specific parameter being changed.""" ;
  gb:edgeIndex 77 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

