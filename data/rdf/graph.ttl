# ==============================================================================
# Edges — cardano: direct triples + gb: EdgeAssertions
# ==============================================================================

n:ada-holder cardano:delegatesVotingPowerTo n:drep .
n:ada-holder gbedge:delegates%20voting%20power%20to n:drep .
e:0 a gb:EdgeAssertion ;
  gb:from n:ada-holder ; gb:to n:drep ; gb:predicate gbedge:delegates%20voting%20power%20to ;
  rdfs:label "delegates voting power to" ; gb:description """Under CIP-1694's liquid democracy model, ada holders delegate their voting power to any registered DRep. The delegated stake counts toward the DRep's vote weight on governance actions. Unlike stake pool delegation, DRep delegation takes effect immediately with no two-epoch lag and can be changed at any time.""" ;
  gb:edgeIndex 0 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:ada-holder cardano:canDelegateTo n:abstain-option .
n:ada-holder gbedge:can%20delegate%20to n:abstain-option .
e:1 a gb:EdgeAssertion ;
  gb:from n:ada-holder ; gb:to n:abstain-option ; gb:predicate gbedge:can%20delegate%20to ;
  rdfs:label "can delegate to" ; gb:description """Ada holders who do not wish to participate in governance can delegate to the pre-defined Abstain option. Stake delegated to Abstain is excluded from the active voting stake denominator, meaning it neither helps nor blocks ratification of any governance action.""" ;
  gb:edgeIndex 1 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:ada-holder cardano:canDelegateTo n:no-confidence-option .
n:ada-holder gbedge:can%20delegate%20to n:no-confidence-option .
e:2 a gb:EdgeAssertion ;
  gb:from n:ada-holder ; gb:to n:no-confidence-option ; gb:predicate gbedge:can%20delegate%20to ;
  rdfs:label "can delegate to" ; gb:description """Ada holders who distrust the current governance state can delegate to No Confidence. This stake IS counted in the active voting stake and automatically votes 'Yes' on every Motion of No-Confidence and 'No' on all other governance actions.""" ;
  gb:edgeIndex 2 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:ada-holder cardano:delegatesStakeTo n:spo .
n:ada-holder gbedge:delegates%20stake%20to n:spo .
e:3 a gb:EdgeAssertion ;
  gb:from n:ada-holder ; gb:to n:spo ; gb:predicate gbedge:delegates%20stake%20to ;
  rdfs:label "delegates stake to" ; gb:description """Ada holders delegate stake to stake pools for block production via Ouroboros Praos. This is separate from DRep delegation — ada holders independently choose who produces blocks and who votes on governance. The pool's total stake also determines the SPO's governance voting weight.""" ;
  gb:edgeIndex 3 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:ada-holder cardano:submits n:governance-action .
n:ada-holder gbedge:submits n:governance-action .
e:4 a gb:EdgeAssertion ;
  gb:from n:ada-holder ; gb:to n:governance-action ; gb:predicate gbedge:submits ;
  rdfs:label "submits" ; gb:description """Any ada holder can submit a governance action on-chain by paying the govActionDeposit (currently 100,000 ada, refundable). The submitter must include a metadata anchor following CIP-100/CIP-108 standards and, for most action types, a reference to the most recently enacted action of the same type.""" ;
  gb:edgeIndex 4 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:ada-holder cardano:canRegisterAs n:drep .
n:ada-holder gbedge:can%20register%20as n:drep .
e:5 a gb:EdgeAssertion ;
  gb:from n:ada-holder ; gb:to n:drep ; gb:predicate gbedge:can%20register%20as ;
  rdfs:label "can register as" ; gb:description """Any ada holder can register as a DRep by paying a refundable dRepDeposit (currently 500 ada). Self-delegation means the holder votes with their own stake weight. This is the 'direct democracy' path in Cardano's liquid democracy model.""" ;
  gb:edgeIndex 5 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:drep cardano:votesOn n:governance-action .
n:drep gbedge:votes%20on n:governance-action .
e:6 a gb:EdgeAssertion ;
  gb:from n:drep ; gb:to n:governance-action ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """DReps vote Yes, No, or Abstain on all seven types of governance actions. Their vote weight equals the total lovelace delegated to them. DReps must vote regularly or become inactive after the dRepActivity period (currently 20 epochs / 100 days).""" ;
  gb:edgeIndex 6 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:spo cardano:votesOn n:action-no-confidence .
n:spo gbedge:votes%20on n:action-no-confidence .
e:7 a gb:EdgeAssertion ;
  gb:from n:spo ; gb:to n:action-no-confidence ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """SPOs vote on Motions of No-Confidence because a dysfunctional CC could block critical protocol upgrades. SPO approval at Q1 = 51% is required alongside DRep approval at 67%.""" ;
  gb:edgeIndex 7 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:spo cardano:votesOn n:action-update-committee .
n:spo gbedge:votes%20on n:action-update-committee .
e:8 a gb:EdgeAssertion ;
  gb:from n:spo ; gb:to n:action-update-committee ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """SPOs vote on Committee Updates because the CC's role in ratifying hard forks and security parameter changes directly affects node operators. SPO approval at Q2a/Q2b = 51% is required.""" ;
  gb:edgeIndex 8 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:spo cardano:votesOn n:action-hard-fork .
n:spo gbedge:votes%20on n:action-hard-fork .
e:9 a gb:EdgeAssertion ;
  gb:from n:spo ; gb:to n:action-hard-fork ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """Hard Fork Initiation requires approval from all three bodies. SPOs must approve at Q4 = 51% because they must actually upgrade their node software. Guardrail HARDFORK-04a requires at least 85% of stake pools to have upgraded before enactment.""" ;
  gb:edgeIndex 9 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:spo cardano:votesOn n:security-params .
n:spo gbedge:votes%20on%20changes%20to n:security-params .
e:10 a gb:EdgeAssertion ;
  gb:from n:spo ; gb:to n:security-params ; gb:predicate gbedge:votes%20on%20changes%20to ;
  rdfs:label "votes on changes to" ; gb:description """Security-relevant parameters (maxBlockBodySize, maxTxSize, txFeePerByte, etc.) directly affect node resource requirements. SPO approval at Q5 = 51% gives infrastructure operators a veto over modifications that could make block production uneconomical or destabilize the network.""" ;
  gb:edgeIndex 10 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:spo cardano:votesOn n:action-info .
n:spo gbedge:votes%20on n:action-info .
e:11 a gb:EdgeAssertion ;
  gb:from n:spo ; gb:to n:action-info ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """SPOs can vote on Info actions to signal their position on community proposals. Since Info actions have no on-chain effect and use a fixed 100% threshold, SPO votes serve purely as a gauge of infrastructure operator sentiment.""" ;
  gb:edgeIndex 11 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:cc cardano:votesOn n:action-new-constitution .
n:cc gbedge:votes%20on n:action-new-constitution .
e:12 a gb:EdgeAssertion ;
  gb:from n:cc ; gb:to n:action-new-constitution ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """The CC must approve constitutional amendments because its mandate is ensuring governance actions comply with the Constitution. CC approval at 2/3 majority is required alongside the highest DRep threshold (75%).""" ;
  gb:edgeIndex 12 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:cc cardano:votesOn n:action-hard-fork .
n:cc gbedge:votes%20on n:action-hard-fork .
e:13 a gb:EdgeAssertion ;
  gb:from n:cc ; gb:to n:action-hard-fork ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """The CC reviews hard fork proposals for constitutional compliance — whether the upgrade respects tenets on transaction freedom, predictable costs, and backward compatibility. CC approval at 2/3 is required alongside DRep and SPO approval.""" ;
  gb:edgeIndex 13 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:cc cardano:votesOn n:action-param-change .
n:cc gbedge:votes%20on n:action-param-change .
e:14 a gb:EdgeAssertion ;
  gb:from n:cc ; gb:to n:action-param-change ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """The CC reviews parameter changes for constitutional compliance, particularly against Appendix I which defines permitted parameter ranges. CC approval at 2/3 majority is required for all parameter groups.""" ;
  gb:edgeIndex 14 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:cc cardano:votesOn n:action-treasury .
n:cc gbedge:votes%20on n:action-treasury .
e:15 a gb:EdgeAssertion ;
  gb:from n:cc ; gb:to n:action-treasury ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """The CC reviews treasury withdrawals for constitutional compliance, including requirements that withdrawals specify purpose, expected costs, and provide for auditable accounts. CC approval at 2/3 is required alongside DRep approval at 67%.""" ;
  gb:edgeIndex 15 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:cc cardano:votesOn n:action-info .
n:cc gbedge:votes%20on n:action-info .
e:16 a gb:EdgeAssertion ;
  gb:from n:cc ; gb:to n:action-info ; gb:predicate gbedge:votes%20on ;
  rdfs:label "votes on" ; gb:description """The CC can vote on Info actions to signal its position. CC members may use CIP-136 metadata to cite specific constitutional articles in their vote rationale, providing constitutional analysis even on non-binding proposals.""" ;
  gb:edgeIndex 16 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:cc cardano:evaluatesAgainst n:constitution .
n:cc gbedge:evaluates%20actions%20against n:constitution .
e:17 a gb:EdgeAssertion ;
  gb:from n:cc ; gb:to n:constitution ; gb:predicate gbedge:evaluates%20actions%20against ;
  rdfs:label "evaluates actions against" ; gb:description """The CC's sole mandate is constitutional review — it evaluates whether governance actions comply with the Cardano Constitution. The CC does NOT assess merit or desirability; it only checks constitutionality. CC members cite specific articles when publishing vote rationales via CIP-136.""" ;
  gb:edgeIndex 17 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:cc prov:used n:hot-cold-keys .
n:cc gbedge:uses n:hot-cold-keys .
e:18 a gb:EdgeAssertion ;
  gb:from n:cc ; gb:to n:hot-cold-keys ; gb:predicate gbedge:uses ;
  rdfs:label "uses" ; gb:description """CC members use a hot/cold key credential system. The cold key is the member's identity, kept offline. The hot key is used for day-to-day voting. If compromised, the hot key can be rotated without changing the member's identity or requiring a Committee Update governance action.""" ;
  gb:edgeIndex 18 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:governance-action cardano:leadsTo n:ratification .
n:governance-action gbedge:undergoes n:ratification .
e:19 a gb:EdgeAssertion ;
  gb:from n:governance-action ; gb:to n:ratification ; gb:predicate gbedge:undergoes ;
  rdfs:label "undergoes" ; gb:description """Every governance action enters ratification for up to govActionLifetime epochs (currently 6 / ~30 days). Ratification is checked only at epoch boundaries. An action can become ratified without new votes if delegation changes shift the stake distribution.""" ;
  gb:edgeIndex 19 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:ratification cardano:leadsTo n:enactment .
n:ratification gbedge:leads%20to n:enactment .
e:20 a gb:EdgeAssertion ;
  gb:from n:ratification ; gb:to n:enactment ; gb:predicate gbedge:leads%20to ;
  rdfs:label "leads to" ; gb:description """Ratified actions are enacted at the next epoch boundary. There is always at least a one-epoch gap. If a high-priority action (No-Confidence, Committee Update, New Constitution, or Hard Fork) is ratified, it delays ratification of all other pending actions until after its enactment.""" ;
  gb:edgeIndex 20 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:governance-action cardano:enables n:voting .
n:governance-action gbedge:open%20for n:voting .
e:21 a gb:EdgeAssertion ;
  gb:from n:governance-action ; gb:to n:voting ; gb:predicate gbedge:open%20for ;
  rdfs:label "open for" ; gb:description """Once submitted, a governance action is immediately available for voting. DRep and SPO votes are stake-weighted; CC votes are one-member-one-vote. Votes can be changed at any time before ratification. Registered stake that did not vote counts as 'No'.""" ;
  gb:edgeIndex 21 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:voting cardano:affects n:ratification .
n:voting gbedge:determines n:ratification .
e:22 a gb:EdgeAssertion ;
  gb:from n:voting ; gb:to n:ratification ; gb:predicate gbedge:determines ;
  rdfs:label "determines" ; gb:description """Accumulated votes determine whether an action meets its thresholds. At each epoch boundary, a fresh tally is calculated using the current stake snapshot. An action is ratified when all required thresholds are simultaneously met.""" ;
  gb:edgeIndex 22 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:governance-action prov:used n:action-chaining .
n:governance-action gbedge:uses n:action-chaining .
e:23 a gb:EdgeAssertion ;
  gb:from n:governance-action ; gb:to n:action-chaining ; gb:predicate gbedge:uses ;
  rdfs:label "uses" ; gb:description """Most action types (except Treasury and Info) must reference the most recently enacted action of the same type. This prevents conflicting same-type actions from both ratifying when they assume incompatible starting states.""" ;
  gb:edgeIndex 23 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-no-confidence rdfs:subClassOf n:governance-action .
n:action-no-confidence gbedge:is%20a%20type%20of n:governance-action .
e:24 a gb:EdgeAssertion ;
  gb:from n:action-no-confidence ; gb:to n:governance-action ; gb:predicate gbedge:is%20a%20type%20of ;
  rdfs:label "is a type of" ; gb:description """Motion of No-Confidence is the highest-priority action type. It requires DRep 67% and SPO 51%. The CC does not vote. When ratified, it blocks the CC from participating until a new committee is elected.""" ;
  gb:edgeIndex 24 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-update-committee rdfs:subClassOf n:governance-action .
n:action-update-committee gbedge:is%20a%20type%20of n:governance-action .
e:25 a gb:EdgeAssertion ;
  gb:from n:action-update-committee ; gb:to n:governance-action ; gb:predicate gbedge:is%20a%20type%20of ;
  rdfs:label "is a type of" ; gb:description """Update Committee can add/remove CC members, set term expirations, and adjust the CC threshold. The CC does not vote. Thresholds differ by CC state: normal DRep 67% + SPO 51%; no-confidence DRep 60% + SPO 51%.""" ;
  gb:edgeIndex 25 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-new-constitution rdfs:subClassOf n:governance-action .
n:action-new-constitution gbedge:is%20a%20type%20of n:governance-action .
e:26 a gb:EdgeAssertion ;
  gb:from n:action-new-constitution ; gb:to n:governance-action ; gb:predicate gbedge:is%20a%20type%20of ;
  rdfs:label "is a type of" ; gb:description """New Constitution / Guardrails Script requires the highest DRep threshold at 75% plus CC 2/3 majority. SPOs do not vote. It can update both the Constitution text and the automated enforcement script.""" ;
  gb:edgeIndex 26 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-hard-fork rdfs:subClassOf n:governance-action .
n:action-hard-fork gbedge:is%20a%20type%20of n:governance-action .
e:27 a gb:EdgeAssertion ;
  gb:from n:action-hard-fork ; gb:to n:governance-action ; gb:predicate gbedge:is%20a%20type%20of ;
  rdfs:label "is a type of" ; gb:description """Hard Fork Initiation is the only action requiring all three bodies: CC 2/3, DReps 60%, SPOs 51%. It specifies a new major protocol version. A ratified hard fork delays all other pending ratifications.""" ;
  gb:edgeIndex 27 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-param-change rdfs:subClassOf n:governance-action .
n:action-param-change gbedge:is%20a%20type%20of n:governance-action .
e:28 a gb:EdgeAssertion ;
  gb:from n:action-param-change ; gb:to n:governance-action ; gb:predicate gbedge:is%20a%20type%20of ;
  rdfs:label "is a type of" ; gb:description """Protocol Parameter Changes modify one or more of ~30 updatable parameters in four groups (Network, Economic, Technical, Governance). Each group has its own DRep threshold. Security-relevant parameters additionally require SPO approval.""" ;
  gb:edgeIndex 28 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-treasury rdfs:subClassOf n:governance-action .
n:action-treasury gbedge:is%20a%20type%20of n:governance-action .
e:29 a gb:EdgeAssertion ;
  gb:from n:action-treasury ; gb:to n:governance-action ; gb:predicate gbedge:is%20a%20type%20of ;
  rdfs:label "is a type of" ; gb:description """Treasury Withdrawal disburses ada from the treasury. Requires CC 2/3 and DRep 67%. Does not require action chaining, allowing multiple independent withdrawals to proceed concurrently.""" ;
  gb:edgeIndex 29 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-info rdfs:subClassOf n:governance-action .
n:action-info gbedge:is%20a%20type%20of n:governance-action .
e:30 a gb:EdgeAssertion ;
  gb:from n:action-info ; gb:to n:governance-action ; gb:predicate gbedge:is%20a%20type%20of ;
  rdfs:label "is a type of" ; gb:description """Info Action has no on-chain effect and uses a fixed 100% threshold. It records community sentiment and polls stakeholders before committing to binding actions. Does not require action chaining.""" ;
  gb:edgeIndex 30 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-param-change cardano:canChange n:param-group-network .
n:action-param-change gbedge:can%20change n:param-group-network .
e:31 a gb:EdgeAssertion ;
  gb:from n:action-param-change ; gb:to n:param-group-network ; gb:predicate gbedge:can%20change ;
  rdfs:label "can change" ; gb:description """Network group includes maxBlockBodySize, maxTxSize, maxBlockHeaderSize, maxValueSize, maxTxExecutionUnits, maxBlockExecutionUnits, and maxCollateralInputs. Changes require CC 2/3 and DRep 67%. Several are security-relevant, additionally requiring SPO 51%.""" ;
  gb:edgeIndex 31 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:action-param-change cardano:canChange n:param-group-economic .
