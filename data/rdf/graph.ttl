  gb:from n:guardrails-script ; gb:to n:action-treasury ; gb:predicate gbedge:constrains ;
  rdfs:label "constrains" ; gb:description """The Guardrails Script enforces treasury withdrawal limits (TREASURY-01a through TREASURY-04a). This automated enforcement ensures treasury funds cannot be drained beyond constitutional bounds even if sufficient votes are gathered.""" ;
  gb:edgeIndex 40 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:constitution cardano:codifiedIn n:guardrails-script .
