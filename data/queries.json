    "id": "who-votes-on",
    "name": "Who Votes on What",
    "description": "All voting relationships — which bodies vote on which action types.",
    "sparql": "PREFIX gb: <https://lambdasistemi.github.io/graph-browser/vocab/terms#>\nPREFIX gbe: <https://lambdasistemi.github.io/graph-browser/vocab/edges#>\nSELECT DISTINCT ?node WHERE {\n  { ?e a gb:EdgeAssertion ; gb:predicate gbe:votes%20on ; gb:from ?node }\n  UNION\n  { ?e a gb:EdgeAssertion ; gb:predicate gbe:votes%20on ; gb:to ?node }\n  UNION\n  { ?e a gb:EdgeAssertion ; gb:predicate gbe:evaluates%20and%20votes%20on ; gb:from ?node }\n  UNION\n  { ?e a gb:EdgeAssertion ; gb:predicate gbe:evaluates%20and%20votes%20on ; gb:to ?node }\n}",
