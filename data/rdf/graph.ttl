  rdfs:label "subject to" ; gb:description """SPO votes are tallied at 51% of active pool stake for all applicable actions: No-Confidence (Q1), Committee Update (Q2a/Q2b), Hard Fork (Q4), security parameters (Q5), and Info (100% fixed).""" ;
  gb:edgeIndex 54 ; dcterms:isPartOf <https://github.com/lambdasistemi/cardano-knowledge-maps/rdf> .

n:cc cardano:subjectTo n:cc-threshold .
